class Solution {
public:
    int maxDifference(string s) {
        vector<int>f(26,0);
        int n=s.size();
        for(int i=0;i<n;i++)
        {
            f[s[i]-'a']++;
        }
        int e=INT_MAX;
        int o=INT_MIN;
        for(int i=0;i<26;i++)
        {
            if(f[i]!=0)
            {
                if((f[i] & 1) ==1)o=max(o,f[i]);
                else e=min(e,f[i]);
            }
        }
        return o-e;
        
    }
};
